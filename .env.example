# Public — safe to expose to the browser (used for admin login + client QR preview)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Private — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Used only inside route handlers (app/c/[slug]/route.ts, admin server actions)
# to bypass RLS for scan logging + admin writes. Set this in Vercel's
# Project Settings → Environment Variables, not in any client-facing file.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL used when building the redirect target encoded into each QR
# e.g. https://qr.whimsiverse.art  (set your final custom domain here)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
